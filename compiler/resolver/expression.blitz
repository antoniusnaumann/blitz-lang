// Expression lowering: AST expressions → HIR expression list
//
// The primary entry point is `lower_body`, which lowers an `ast::Block` into
// a `hir::Body` (an expression list plus bindings).  Internally every node
// is flattened into a `List(hir::Expression)` via `lower_expr` / `lower_stmt` and
// referenced by an `ExpressionId`.  Once lowering is complete, the list and
// the bindings collected from the `ScopeArena` are combined into the final
// `Body`.
//
// Name resolution strategy
// ─────────────────────────
// • Local variables are resolved through a `ScopeArena` that tracks bindings.
// • Function calls produce a *candidate list* of `FuncId`s found by name
//   across accessible modules. The type checker will narrow the list to a single overload.
// • Constructors resolve the type name to a `TypeId` when possible; if the
//   type is not found a placeholder id is used and a diagnostic is emitted.
// • `else` operator (binary): lowered as a BinaryOp so the type checker can
//   later understand it as "unwrap or short-circuit".

// ── Resolver ─────────────────────────────────────────────────────────────────

struct Resolver {
	errors List(ast::Error)
}

fn new_resolver() Resolver {
	Resolver(errors: [])
}

fn err(mut resolver Resolver, msg String, span ast::Span) {
	resolver.errors ++= ast::Error(span:, msg:)
}

// ── Candidate resolution ─────────────────────────────────────────────────────

// Collect all FuncDef IDs whose name matches `name` that are visible from
// the current module.  Searches: qualified module (if given) → current module
// → core module → all other modules (for UFCS whose receiver type determines
// the module).
// TODO: the 'all other modules' rule will be removed in the future and std will be imported implicitly
fn find_candidates(hir hir::Hir, mod_id hir::ModId, name String, module Option(ast::Ident)) List(hir::FuncId) {
	var candidates = []

	if module != none {
		// Qualified call: module::func(...)
		let mod_name = module.unwrap().name
		let target = hir.find(mod_name)
		if target != none {
			collect_func_candidates(hir, target.unwrap(), name, mut candidates)
		}
		return candidates
	}

	// Current module
	collect_func_candidates(hir, mod_id, name, mut candidates)

	// Core module, unless current module is core
	if mod_id.id != hir::core_mod_id().id {
		collect_func_candidates(hir, hir::core_mod_id(), name, mut candidates)
	}

	// All other modules (to handle UFCS where receiver's module is unknown
	// until the type checker resolves the receiver type)
	// TODO: this will be more fine-grained in the future and only point to std
	var i = 1
	while i < hir.mods.len() {
		if i != mod_id.id {
			collect_func_candidates(hir, hir::ModId(id: i), name, mut candidates)
		}
		i += 1
	}

	candidates
}


fn collect_func_candidates(hir hir::Hir, mod_id hir::ModId, name String, mut out List(hir::FuncId)) {
	let mod = hir.get(mod_id)
	var i = 0
	while i < mod.funcs.len() {
		if mod.funcs[i].name.name == name {
			out ++= hir::FuncId(module: mod_id, id: i)
		}
		i += 1
	}
}

// Resolve a type name to a TypeId.  Returns `none` and emits a diagnostic if
// the type cannot be found.
fn resolve_type_id(hir hir::Hir, mod_id hir::ModId, mut resolver Resolver, ty ast::Type) Option(hir::TypeId) {
	if ty.module != none {
		let mod_name = ty.module.unwrap().name
		let target = hir.find(mod_name)
		if target == none {
			resolver.mut.err("Unknown module '" ++ mod_name ++ "'", ty.span)
			return none
		}
		let found = hir.find_type(target.unwrap(), ty.name)
		if found == none {
			resolver.mut.err("Unknown type '" ++ ty.name ++ "' in module '" ++ mod_name ++ "'", ty.span)
			return none
		}
		return found.unwrap()
	}

	// Try current module first, then core
	let in_mod = hir.find_type(mod_id, ty.name)
	if in_mod != none { return in_mod.unwrap() }

	let in_core = hir.find_type(hir::core_mod_id(), ty.name)
	if in_core == none {
		resolver.mut.err("Unknown type '" ++ ty.name ++ "'", ty.span)
	}
	in_core
}

// ── Body lowering ─────────────────────────────────────────────────────────────

// Lower an ast::Block into a hir::Body. Populates a fresh ScopeArena for
// the function body.
fn lower_body(block ast::Block, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::Body {
	lower_body(block, [], hir, mod_id, mut resolver)
}

// Resolve the type annotation of a function parameter to an Option(TypeRef).
fn resolve_param_type(param ast::Arg, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) Option(hir::TypeRef) {
	let type_id = resolve_type_id(hir, mod_id, mut resolver, param.type)
	if type_id == none {
		return none
	}
	hir::TypeRef(id: type_id.unwrap().id)
}

// Lower an ast::Block that also takes parameters as pre-declared bindings.
fn lower_body(block ast::Block, params List(ast::Arg), hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::Body {
	var expressions = []
	var scope_arena = hir::new_scope_arena()
	let root_scope = scope_arena.mut.push_root()

	for params |param| {
		let type_ref = resolve_param_type(param, hir, mod_id, mut resolver)
		scope_arena.mut.define(root_scope, param.name, param.is_mut, type_ref)
	}

	lower_block(block, mut expressions, mut scope_arena, root_scope, hir, mod_id, mut resolver)

	Body(expressions:, bindings: scope_arena.collect_bindings())
}

// ── Block lowering ────────────────────────────────────────────────────────────

// Lower the statements of `block` into the arena, in a fresh child scope.
// Returns the ExpressionId of a Block node that lists the statement IDs.
fn lower_block(block ast::Block, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, parent_scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let scope = scope_arena.mut.push_child(parent_scope)
	var stmt_ids = []

	for block.statements |stmt| {
		stmt_ids ++= lower_stmt(stmt, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	}

	expressions.mut.push(hir::Expression(kind: hir::Block(stmts: stmt_ids), span: block.span))
}

// ── Statement lowering ────────────────────────────────────────────────────────

fn lower_stmt(stmt ast::Statement, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	switch stmt {
		ast::Declaration { lower_decl(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Expression  { lower_expr(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
	}
}

// Resolve the optional explicit type annotation in a declaration.
// Returns none if no annotation is present or if the type cannot be resolved.
fn resolve_decl_type(decl ast::Declaration, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) Option(hir::TypeRef) {
	if decl.type == none {
		return none
	}
	let ty = decl.type.unwrap()
	let type_id = resolve_type_id(hir, mod_id, mut resolver, ty)
	if type_id == none {
		return none
	}
	hir::TypeRef(id: type_id.unwrap().id)
}

fn lower_decl(decl ast::Declaration, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let init_id = lower_expr(decl.init, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	let type_ref_opt = resolve_decl_type(decl, hir, mod_id, mut resolver)
	let binding_id = scope_arena.mut.define(scope, decl.name, decl.is_mut, type_ref_opt)

	expressions.mut.push(hir::Expression(
		kind: hir::Let(name: decl.name, type_: type_ref_opt, init: init_id, is_mut: decl.is_mut, binding_id:),
		span: decl.span
	))
}

// ── Expression lowering ───────────────────────────────────────────────────────

fn lower_expr(expr ast::Expression, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	switch expr {
		ast::Literal    { lower_literal(it, mut expressions) }
		ast::Ident      { lower_ident(it, mut expressions, scope_arena, scope, hir, mod_id) }
		ast::Call       { lower_call(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Constructor { lower_constructor(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Member     { lower_member(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::BinaryOp   { lower_binary_op(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::UnaryOp    { lower_unary_op(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Assignment { lower_assignment(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::If         { lower_if(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::While      { lower_while(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::For        { lower_for(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Switch     { lower_switch(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Block      { lower_block(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Return     { lower_return(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Break      { expressions.mut.push(hir::Expression(kind: hir::Break(), span: it.span)) }
		ast::Continue   { expressions.mut.push(hir::Expression(kind: hir::Continue(), span: it.span)) }
		ast::Assert     { lower_assert(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Mut        { lower_mut(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Try        { lower_try(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::List_      { lower_list(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Index      { lower_index(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
		ast::Group      { lower_group(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver) }
	}
}

// ── Literals ──────────────────────────────────────────────────────────────────

fn lower_literal(lit ast::Literal, mut expressions List(hir::Expression)) hir::ExpressionId {
	switch lit {
		ast::Lit(Int)    { expressions.mut.push(hir::Expression(kind: hir::LitInt(value: it.value), span: it.span)) }
		ast::Lit(Float)  { expressions.mut.push(hir::Expression(kind: hir::LitFloat(value: it.value), span: it.span)) }
		ast::Lit(String) { expressions.mut.push(hir::Expression(kind: hir::LitString(value: it.value), span: it.span)) }
		ast::Lit(Rune)   { expressions.mut.push(hir::Expression(kind: hir::LitRune(value: it.value), span: it.span)) }
	}
}

// ── Identifier ───────────────────────────────────────────────────────────────
// An `ast::Ident` is either a local variable reference or a bare union-case
// label (e.g. `none`, `true`, `false`, or a label-only case like `public`).
// In the HIR we emit `LocalRef` for known bindings and a zero-argument `Call`
// with candidates for everything else (the type checker will resolve it).

fn lower_ident(ident ast::Ident, mut expressions List(hir::Expression), scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId) hir::ExpressionId {
	let binding = scope_arena.lookup(scope, ident.name)
	if binding != none {
		return expressions.mut.push(hir::Expression(kind: hir::LocalRef(binding_id: binding.unwrap().binding_id), span: ident.span))
	}

	// TODO LLM: this should be a hir::IdentCase, not a call. there needs to be a find_case function
	// Not a local — treat as a zero-argument call so candidate resolution
	// can find the right enum case or nullary function.
	let candidates = find_candidates(hir, mod_id, ident.name, none)
	expressions.mut.push(hir::Expression(kind: hir::Call(name: ident, module: none, candidates:, args: []), span: ident.span))
}

// ── Calls ─────────────────────────────────────────────────────────────────────

fn lower_call(call ast::Call, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let candidates = find_candidates(hir, mod_id, call.name.name, call.module)
	var args = []
	for call.args |arg| {
		let value = lower_expr(arg.init, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
		args ++= hir::Argument(label: arg.label, value:)
	}
	expressions.mut.push(hir::Expression(kind: hir::Call(name: call.name, module: call.module, candidates:, args:), span: call.span))
}

// ── Constructors ──────────────────────────────────────────────────────────────

fn lower_constructor(constructor ast::Constructor, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	// Resolve the type name to a TypeId (best-effort; unknown types get id 0)
	let type_id = resolve_type_id(hir, mod_id, mut resolver, constructor.type)
	let resolved_id = if type_id != none {
		type_id.unwrap()
	} else {
		hir::TypeId(module: mod_id, id: 0)
	}

	var args = []
	for constructor.args |arg| {
		let value = lower_expr(arg.init, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
		args ++= hir::FieldInit(label: arg.label, value:)
	}

	expressions.mut.push(hir::Expression(
		kind: hir::Constructor(type_id: resolved_id, type_name: ast::Ident(name: constructor.type.name, span: constructor.type.span), args:),
		span: constructor.span
	))
}

// ── Member access ─────────────────────────────────────────────────────────────

fn lower_member(member ast::Member, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let expr_id = lower_expr(member.parent, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	expressions.mut.push(hir::Expression(kind: hir::Member(expr: expr_id, field: member.member), span: member.span))
}

// ── Binary / unary operations ─────────────────────────────────────────────────

fn lower_binary_op(op ast::BinaryOp, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let left_id  = lower_expr(op.left, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	let right_id = lower_expr(op.right, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	expressions.mut.push(hir::Expression(kind: hir::BinaryOp(op: op.op, left: left_id, right: right_id), span: op.span))
}

fn lower_unary_op(op ast::UnaryOp, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let expr_id = lower_expr(op.expr, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	expressions.mut.push(hir::Expression(kind: hir::UnaryOp(op: op.op, expr: expr_id), span: op.span))
}

// ── Assignment ────────────────────────────────────────────────────────────────

fn lower_assignment(assign ast::Assignment, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let target_id = lower_expr(assign.left, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	let value_id  = lower_expr(assign.right, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	// TODO: ast::Assignment has no span field (unlike other expression structs).
	// Add `span Span` to Assignment and populate it in the parser.
	expressions.mut.push(hir::Expression(kind: hir::Assign(target: target_id, value: value_id), span: ast::empty_span()))
}

// ── Control flow ──────────────────────────────────────────────────────────────

fn lower_if(if_ ast::If, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let cond_id = lower_expr(if_.cond, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	let then_id = lower_block(if_.body, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	// If-else is represented as BinaryOp(op: else_, left: If(...), right: Block(...)),
	// mirroring the AST structure.  The If node only holds the condition and then-body.
	expressions.mut.push(hir::Expression(kind: hir::If(cond: cond_id, then_body: then_id), span: if_.span))
}

fn lower_while(while_ ast::While, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let cond_id = lower_expr(while_.cond, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	let body_id = lower_block(while_.body, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	expressions.mut.push(hir::Expression(kind: hir::While(cond: cond_id, body: body_id), span: while_.span))
}

fn lower_for(for_ ast::For, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let iter_id = lower_expr(for_.iter, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)

	// The loop binding is visible inside the body only.
	let inner_scope = scope_arena.mut.push_child(scope)
	scope_arena.mut.define(inner_scope, for_.elem, false, none)

	let body_id = lower_block(for_.body, mut expressions, mut scope_arena, inner_scope, hir, mod_id, mut resolver)
	expressions.mut.push(hir::Expression(kind: hir::For(iter: iter_id, binding: for_.elem, body: body_id), span: for_.span))
}

fn lower_switch(switch_ ast::Switch, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let cond_id = lower_expr(switch_.cond, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)

	var hir_cases = []
	for switch_.cases |case| {
		let label = lower_switch_label(case.label, mut expressions, hir, mod_id, mut resolver)
		let case_body = lower_block(case.body, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
		hir_cases ++= hir::SwitchCase(label:, body: case_body, span: case.span)
	}

	expressions.mut.push(hir::Expression(kind: hir::Switch(cond: cond_id, cases: hir_cases), span: switch_.span))
}

fn lower_switch_label(label ast::SwitchLabel, mut expressions List(hir::Expression), hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::SwitchLabel {
	switch label {
		ast::Type {
			let type_id = resolve_type_id(hir, mod_id, mut resolver, it)
			let resolved = if type_id != none {
				type_id.unwrap()
			} else {
				hir::TypeId(module: mod_id, id: 0)
			}
			hir::TypeCase(type_id: resolved, type_name: ast::Ident(name: it.name, span: it.span))
		}
		ast::Ident {
			hir::IdentCase(name: it)
		}
		ast::Literal {
			let expr_id = lower_literal(it, mut expressions)
			hir::LiteralCase(value: expr_id)
		}
		default { default }
	}
}

// ── Return ────────────────────────────────────────────────────────────────────

fn lower_return(ret ast::Return, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	switch ret.expr {
		ast::Block {
			// The parser encodes "empty return" as `Return(expr: Block(statements: [], ...))`.
			// Detect that case and emit `Return(expr: none)`.
			if it.statements.len() == 0 {
				return expressions.mut.push(hir::Expression(kind: hir::Return(expr: none), span: ret.span))
			}
			let expr_id = lower_block(it, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
			expressions.mut.push(hir::Expression(kind: hir::Return(expr: expr_id), span: ret.span))
		}
		else {
			let expr_id = lower_expr(ret.expr, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
			expressions.mut.push(hir::Expression(kind: hir::Return(expr: expr_id), span: ret.span))
		}
	}
}

// ── Special operators ─────────────────────────────────────────────────────────

fn lower_assert(assertion ast::Assert, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let cond_id = lower_expr(assertion.cond, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	expressions.mut.push(hir::Expression(kind: hir::Assert(cond: cond_id), span: assertion.span))
}

fn lower_mut(mut_ ast::Mut, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let expr_id = lower_expr(mut_.expr, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	expressions.mut.push(hir::Expression(kind: hir::Mut(expr: expr_id), span: mut_.span))
}

fn lower_try(try_ ast::Try, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let expr_id = lower_expr(try_.expr, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	expressions.mut.push(hir::Expression(kind: hir::Try(expr: expr_id), span: try_.span))
}

fn lower_list(list ast::List_, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	var elem_ids = []
	for list.elems |elem| {
		elem_ids ++= lower_expr(elem, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	}
	expressions.mut.push(hir::Expression(kind: hir::ListLit(elems: elem_ids), span: list.span))
}

fn lower_index(index ast::Index, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let target_id = lower_expr(index.target, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	let index_id  = lower_expr(index.index, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	expressions.mut.push(hir::Expression(kind: hir::Index(target: target_id, index: index_id), span: index.span))
}

fn lower_group(group ast::Group, mut expressions List(hir::Expression), mut scope_arena hir::ScopeArena, scope hir::ScopeId, hir hir::Hir, mod_id hir::ModId, mut resolver Resolver) hir::ExpressionId {
	let expr_id = lower_expr(group.expr, mut expressions, mut scope_arena, scope, hir, mod_id, mut resolver)
	expressions.mut.push(hir::Expression(kind: hir::Group(expr: expr_id), span: group.span))
}
