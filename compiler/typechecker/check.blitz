struct TypeChecker {
	hir    hir::Hir
	errors List(ast::Error)
}

fn err(mut checker TypeChecker, span Span, msg String) {
	checker.errors ++= ast::Error(span:, msg:)
}

fn never_ref(mut checker TypeChecker) hir::TypeRef {
	let never_id = checker.hir.find_core_type("Never")
	checker.hir.mut.insert(never_id)
}

// for now, this reuses the Hir structure and just adds typing. In the future, the Hir might be generic and be either Hir(Untyped) or Hir(Typed)
fn check(mut checker TypeChecker) hir::Hir {
	var typed_hir = checker.hir // copy that will be enriched with types
}

fn check(mut checker TypeChecker, body hir::Body) {
	for body.expressions |expr| {
		checker.mut.check(body, expr)
	}
}

// checks the expression recursively returns the inferred type
// TODO: TypeRef is probably not enough, we need to include mutability
fn check(mut checker TypeChecker, body hir::Body, expr hir::Expression) hir::TypeRef {
	switch expr.kind {
		LitInt { checker.mut.check(body, it) }
		LitFloat { checker.mut.check(body, it) }
		LitString { checker.mut.check(body, it) }
		LitRune { checker.mut.check(body, it) }
		LocalRef { checker.mut.check(body, it) }
		UnionCase { checker.mut.check(body, it) }
		BinaryOp { checker.mut.check(body, it) }
		UnaryOp { checker.mut.check(body, it) }
		Call { checker.mut.check(body, it) }
		Constructor { checker.mut.check(body, it) }
		Member { checker.mut.check(body, it) }
		Index { checker.mut.check(body, it) }
		If { checker.mut.check(body, it) }
		While { checker.mut.check(body, it) }
		For { checker.mut.check(body, it) }
		Switch { checker.mut.check(body, it) }
		Block { checker.mut.check(body, it) }
		Return { checker.mut.check(body, it) }
		Break { checker.mut.check(body, it) }
		Continue { checker.mut.check(body, it) }
		Let { checker.mut.check(body, it) }
		Assign { checker.mut.check(body, it) }
		Assert { checker.mut.check(body, it) }
		Mut { checker.mut.check(body, it) }
		Try { checker.mut.check(body, it) }
		ListLit { checker.mut.check(body, it) }
		Group { checker.mut.check(body, it) }
	}
}

fn check(mut checker TypeChecker, body hir::Body, expr hir::LitInt) hir::TypeRef {
	let id = checker.hir.find_core_type("Int")
	checker.hir.mut.insert(id)
}

fn check(mut checker TypeChecker, body hir::Body, expr hir::LitFloat) hir::TypeRef {
	let id = checker.hir.find_core_type("Float")
	checker.hir.mut.insert(id)
}

fn check(mut checker TypeChecker, body hir::Body, expr hir::LitString) hir::TypeRef {
	let id = checker.hir.find_core_type("String")
	checker.hir.mut.insert(id)
}

fn check(mut checker TypeChecker, body hir::Body, expr hir::LitRune) hir::TypeRef {
	let id = checker.hir.find_core_type("Rune")
	checker.hir.mut.insert(id)
}

fn check(mut checker TypeChecker, body hir::Body, expr hir::LocalRef) hir::TypeRef {
	let binding = body.bindings[expr.binding_id]
	// SAFETY: at this point, the type checker will have filled in the binding type already
	binding.type.unwrap()
}

