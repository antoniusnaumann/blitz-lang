fn check(mut checker TypeChecker, body hir::Body, member hir::Member) hir::TypeRef {
	let parent = body.get(member.parent)
	let p_ref  = checker.mut.check(body, parent)
	let p_kind = checker.hir.get(p_ref)
	switch p_kind {
		Nominal {
			let p_def = checker.hir.get(it.def_id)
			switch p_def.kind {
				StructDef {
					for it.fields |f| {
						if f.name.name == member.field.name {
							return f.type
						}
					}
					// TODO: Improve error message once string formatting is implemented + introduce a union for error types instead of hardcoding strings
					checker.mut.err(member.field.span, "No matching field on parent")
					checker.mut.never_ref()
				}
				UnionDef {
					checker.mut.err(member.field.span, "Cannot access field on union type")
					checker.mut.never_ref()
				}
				builtin {
					checker.mut.err(member.field.span, "Cannot access field on builtin type")
					checker.mut.never_ref()
				}
			}
		}
		GenericId {
			checker.mut.err(member.field.span, "Cannot access field on generic type")
			checker.mut.never_ref()
		}
	}
}

