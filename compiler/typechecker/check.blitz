struct TypeChecker {
	errors List(ast::Error)
}

// for now, this reuses the Hir structure and just adds typing. In the future, the Hir might be generic and be either Hir(Untyped) or Hir(Typed)
fn check(mut checker TypeChecker, hir hir::Hir) hir::Hir {
	var typed_hir = hir // copy that will be enriched with types
}

fn check(mut checker TypeChecker, hir hir::Hir, body hir::Body) {
	for body.expressions |expr| {
		checker.mut.check(hir, body)
	}
}

// checks the expression recursively returns the inferred type
// TODO: TypeRef is probably not enough, we need to include mutability
// TODO LLM: instead of the exprs being passed around here, body hir::Body should be passed around
fn check(mut checker TypeChecker, hir hir::Hir, exprs List(hir::Expression), expr hir::Expression) hir::TypeRef {
	switch expr.kind {
		LitInt { check(mut checker, hir, exprs, it) }
		LitFloat { check(mut checker, hir, exprs, it) }
		LitString { check(mut checker, hir, exprs, it) }
		LitRune { check(mut checker, hir, exprs, it) }
		LocalRef { check(mut checker, hir, exprs, it) }
		UnionCase { check(mut checker, hir, exprs, it) }
		BinaryOp { check(mut checker, hir, exprs, it) }
		UnaryOp { check(mut checker, hir, exprs, it) }
		Call { check(mut checker, hir, exprs, it) }
		Constructor { check(mut checker, hir, exprs, it) }
		Member { check(mut checker, hir, exprs, it) }
		Index { check(mut checker, hir, exprs, it) }
		If { check(mut checker, hir, exprs, it) }
		While { check(mut checker, hir, exprs, it) }
		For { check(mut checker, hir, exprs, it) }
		Switch { check(mut checker, hir, exprs, it) }
		Block { check(mut checker, hir, exprs, it) }
		Return { check(mut checker, hir, exprs, it) }
		Break { check(mut checker, hir, exprs, it) }
		Continue { check(mut checker, hir, exprs, it) }
		Let { check(mut checker, hir, exprs, it) }
		Assign { check(mut checker, hir, exprs, it) }
		Assert { check(mut checker, hir, exprs, it) }
		Mut { check(mut checker, hir, exprs, it) }
		Try { check(mut checker, hir, exprs, it) }
		ListLit { check(mut checker, hir, exprs, it) }
		Group { check(mut checker, hir, exprs, it) }
	}
}

fn check(mut checker TypeChecker, hir hir::Hir, exprs List(hir::Expression), expr hir::LitInt) hir::TypeRef {
	hir.find_core_type("Int")
}

fn check(mut checker TypeChecker, hir hir::Hir, exprs List(hir::Expression), expr hir::LitFloat) hir::TypeRef {
	hir.find_core_type("Float")
}

fn check(mut checker TypeChecker, hir hir::Hir, exprs List(hir::Expression), expr hir::LitString) hir::TypeRef {
	hir.find_core_type("String")
}

fn check(mut checker TypeChecker, hir hir::Hir, exprs List(hir::Expression), expr hir::LitRune) hir::TypeRef {
