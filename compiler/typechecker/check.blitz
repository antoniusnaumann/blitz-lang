struct TypeChecker {
	errors List(ast::Error)
}

fn err(mut checker TypeChecker, span Span, msg String) {
	checker.errors ++= ast::Error(span:, msg:)
}

// for now, this reuses the Hir structure and just adds typing. In the future, the Hir might be generic and be either Hir(Untyped) or Hir(Typed)
fn check(mut checker TypeChecker, hir hir::Hir) hir::Hir {
	var typed_hir = hir // copy that will be enriched with types
}

fn check(mut checker TypeChecker, hir hir::Hir, body hir::Body) {
	for body.expressions |expr| {
		checker.mut.check(hir, body, expr)
	}
}

// checks the expression recursively returns the inferred type
// TODO: TypeRef is probably not enough, we need to include mutability
fn check(mut checker TypeChecker, hir hir::Hir, body hir::Body, expr hir::Expression) hir::TypeRef {
	// TODO LLM: make all these UFCS syntax, so checker.mut.check(...)
	switch expr.kind {
		LitInt { check(mut checker, hir, body, it) }
		LitFloat { check(mut checker, hir, body, it) }
		LitString { check(mut checker, hir, body, it) }
		LitRune { check(mut checker, hir, body, it) }
		LocalRef { check(mut checker, hir, body, it) }
		UnionCase { check(mut checker, hir, body, it) }
		BinaryOp { check(mut checker, hir, body, it) }
		UnaryOp { check(mut checker, hir, body, it) }
		Call { check(mut checker, hir, body, it) }
		Constructor { check(mut checker, hir, body, it) }
		Member { check(mut checker, hir, body, it) }
		Index { check(mut checker, hir, body, it) }
		If { check(mut checker, hir, body, it) }
		While { check(mut checker, hir, body, it) }
		For { check(mut checker, hir, body, it) }
		Switch { check(mut checker, hir, body, it) }
		Block { check(mut checker, hir, body, it) }
		Return { check(mut checker, hir, body, it) }
		Break { check(mut checker, hir, body, it) }
		Continue { check(mut checker, hir, body, it) }
		Let { check(mut checker, hir, body, it) }
		Assign { check(mut checker, hir, body, it) }
		Assert { check(mut checker, hir, body, it) }
		Mut { check(mut checker, hir, body, it) }
		Try { check(mut checker, hir, body, it) }
		ListLit { check(mut checker, hir, body, it) }
		Group { check(mut checker, hir, body, it) }
	}
}

fn check(mut checker TypeChecker, hir hir::Hir, body hir::Body, expr hir::LitInt) hir::TypeRef {
	hir.find_core_type("Int")
}

fn check(mut checker TypeChecker, hir hir::Hir, body hir::Body, expr hir::LitFloat) hir::TypeRef {
	hir.find_core_type("Float")
}

fn check(mut checker TypeChecker, hir hir::Hir, body hir::Body, expr hir::LitString) hir::TypeRef {
	hir.find_core_type("String")
}

fn check(mut checker TypeChecker, hir hir::Hir, body hir::Body, expr hir::LitRune) hir::TypeRef {
	hir.find_core_type("Rune")
}

fn check(mut checker TypeChecker, hir hir::Hir, body hir::Body, expr hir::LocalRef) hir::TypeRef {
	let binding = body.bindings[expr.binding_id]
	// SAFETY: at this point, the type checker will have filled in the binding type already
	binding.type.unwrap()
}

