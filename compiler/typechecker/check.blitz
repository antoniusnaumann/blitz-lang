fn check(mut checker TypeChecker, hir hir::Hir, body hir::Body, expr hir::Member) hir::TypeRef {
	let parent = body.get(member.parent)
	let p_type = checker.mut.check(hir, body, parent)

	for p_type.fields |f| {
		if f.ident.name == expr.field.name {
			return f.type
		}
	}

	// TODO: Improve error message once string formatting is implemented + introduce a union for error types instead of hardcoding strings
	checker.mut.err(expr.field.span, "No matching field on parent")
	hir.find_core_type("Never")
}

